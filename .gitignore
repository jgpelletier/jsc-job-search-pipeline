# Pipeline state — created and mutated by the agent, do not commit
pipeline.db
pipeline.db-journal
backups/

# Session-state file — recreated each session
HANDOFF.md

# Inbox — personal screenshots, never commit
inbox/*
!inbox/processed/
inbox/processed/*
!inbox/processed/.gitkeep

# Per-role analysis artifacts — generated by skills, contain personal job search content
references/analyses/*
!references/analyses/README.md

# Local Claude Code overrides — keep your own permissions out of the shared repo
.claude/settings.local.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
